package internal

import (
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"net/url"
	"os"
	"strings"
	"time"
)

// Client wraps HTTP calls to the {{ spec.name }} API.
type Client struct {
	BaseURL   string
	AuthToken string
	HTTP      *http.Client
}

// NewClient creates a client. A non-empty baseOverride (from --base-url) wins
// over the {{ spec.name | upper | replace('-', '_') }}_BASE_URL env var and the spec default.
func NewClient(baseOverride string) *Client {
	base := baseOverride
	if base == "" {
		base = os.Getenv("{{ spec.name | upper | replace('-', '_') }}_BASE_URL")
	}
	if base == "" {
		base = "{{ spec.base_url }}"
	}
	return &Client{
		BaseURL:   base,
		AuthToken: os.Getenv("{{ spec.name | upper | replace('-', '_') }}_TOKEN"),
		HTTP:      &http.Client{Timeout: 30 * time.Second},
	}
}

// APIError is returned for non-2xx responses.
type APIError struct {
	Status int         `json:"status"`
	Body   interface{} `json:"body"`
}

func (e *APIError) Error() string { return fmt.Sprintf("HTTP %d", e.Status) }

// ExitCode maps an HTTP status to the shared DuckTap exit-code palette.
func (e *APIError) ExitCode() int {
	switch {
	case e.Status == 404:
		return 3
	case e.Status == 401 || e.Status == 403:
		return 4
	case e.Status == 429:
		return 7
	default:
		return 5
	}
}

// JSON renders the error as pretty JSON for stderr.
func (e *APIError) JSON() string {
	b, _ := json.MarshalIndent(e, "", "  ")
	return string(b)
}

// BuildURL assembles the full request URL including the query string.
func (c *Client) BuildURL(path string, query map[string]string) string {
	full := c.BaseURL + path
	if len(query) > 0 {
		vals := url.Values{}
		for k, v := range query {
			vals.Set(k, v)
		}
		full += "?" + vals.Encode()
	}
	return full
}

// Request performs an HTTP request and returns the decoded body. Non-2xx
// responses are returned as *APIError.
func (c *Client) Request(method, path string, query map[string]string, body io.Reader) (interface{}, error) {
	req, err := http.NewRequest(method, c.BaseURL+path, body)
	if err != nil {
		return nil, err
	}
	if c.AuthToken != "" {
		req.Header.Set("Authorization", "Bearer "+c.AuthToken)
	}
	req.Header.Set("Accept", "application/json")
	if body != nil {
		req.Header.Set("Content-Type", "application/json")
	}
	for k, v := range query {
		q := req.URL.Query()
		q.Set(k, v)
		req.URL.RawQuery = q.Encode()
	}
	resp, err := c.HTTP.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()
	if resp.StatusCode >= 400 {
		var b interface{}
		_ = json.NewDecoder(resp.Body).Decode(&b)
		return nil, &APIError{Status: resp.StatusCode, Body: b}
	}
	var result interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}
	return result, nil
}

// PrettyJSON returns a pretty-printed JSON string.
func PrettyJSON(v interface{}) string {
	b, _ := json.MarshalIndent(v, "", "  ")
	return string(b)
}

// ReplacePathParam substitutes a path parameter placeholder with a value.
func ReplacePathParam(path, placeholder, value string) string {
	return strings.Replace(path, placeholder, value, 1)
}
