use reqwest::Client;
use serde_json::{json, Value};
use std::env;

/// Global options threaded from the top-level CLI into each command.
pub struct GlobalOpts {
    pub base_url: Option<String>,
    pub dry_run: bool,
}

/// Returned for non-2xx responses so `main` can map the status to an exit code.
#[derive(Debug)]
pub struct ApiError {
    pub status: u16,
    pub body: Value,
}

impl std::fmt::Display for ApiError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "HTTP {}", self.status)
    }
}

impl std::error::Error for ApiError {}

impl ApiError {
    /// Map an HTTP status to the shared DuckTap exit-code palette.
    pub fn exit_code(&self) -> i32 {
        match self.status {
            404 => 3,
            401 | 403 => 4,
            429 => 7,
            _ => 5,
        }
    }

    pub fn to_json(&self) -> String {
        serde_json::to_string_pretty(&json!({"status": self.status, "body": self.body}))
            .unwrap_or_else(|_| self.to_string())
    }
}

pub struct ApiClient {
    client: Client,
    base_url: String,
    auth_token: Option<String>,
}

impl ApiClient {
    /// A non-empty `base_override` (from --base-url) wins over the
    /// {{ spec.name | upper | replace('-', '_') }}_BASE_URL env var and the spec default.
    pub fn new(base_override: Option<&str>) -> Self {
        let base_url = base_override
            .map(|s| s.to_string())
            .or_else(|| env::var("{{ spec.name | upper | replace('-', '_') }}_BASE_URL").ok())
            .unwrap_or_else(|| "{{ spec.base_url }}".to_string());
        let auth_token = env::var("{{ spec.name | upper | replace('-', '_') }}_TOKEN").ok();
        Self {
            client: Client::new(),
            base_url,
            auth_token,
        }
    }

    pub fn build_url(&self, path: &str) -> String {
        format!("{}{}", self.base_url, path)
    }

    pub async fn request(
        &self,
        method: &str,
        path: &str,
        query: &[(String, String)],
        body: Option<Value>,
    ) -> anyhow::Result<Value> {
        let url = format!("{}{}", self.base_url, path);
        let mut req = self.client.request(
            reqwest::Method::from_bytes(method.as_bytes())?,
            &url,
        );
        if let Some(token) = &self.auth_token {
            req = req.header("Authorization", format!("Bearer {}", token));
        }
        req = req.query(query);
        if let Some(b) = body {
            req = req.json(&b);
        }
        let resp = req.send().await?;
        let status = resp.status();
        if !status.is_success() {
            let body = resp.json::<Value>().await.unwrap_or(Value::Null);
            return Err(ApiError { status: status.as_u16(), body }.into());
        }
        Ok(resp.json().await?)
    }
}
