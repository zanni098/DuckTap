use clap::Args;
use serde_json::json;

use crate::client::ApiClient;

{% for op in operations %}
#[derive(Args)]
pub struct {{ op.operation_id | cmd | rustident }}Args {
    {% for p in op.params if p.location == 'path' %}
    /// {{ p.description }}
    pub {{ p.name | rustident }}: {{ p | rusttype }},
    {% endfor %}
    {% for p in op.params if p.location in ['query', 'body', 'header'] %}
    #[arg(long = "{{ p.name | flag }}")]
    /// {{ p.description }}
    pub {{ p.name | rustident }}: Option<{{ p | rusttype }}>,
    {% endfor %}
}

pub async fn {{ op.operation_id | cmd | rustident }}(args: {{ op.operation_id | cmd | rustident }}Args) -> anyhow::Result<()> {
    let client = ApiClient::new();
    let path = "{{ op.path }}"
        {% for p in op.params if p.location == 'path' %}
        .replace("{{ '{' + p.name + '}' }}", &args.{{ p.name | rustident }}.to_string())
        {% endfor %};
    {% if op.params | selectattr('location', 'equalto', 'query') | list %}
    let mut query = vec![];
    {% for p in op.params if p.location == 'query' %}
    if let Some(v) = args.{{ p.name | rustident }} {
        query.push(("{{ p.name }}", v.to_string().as_str()));
    }
    {% endfor %}
    {% else %}
    let query = vec![];
    {% endif %}
    {% if op.params | selectattr('location', 'equalto', 'body') | list %}
    let mut body_map = serde_json::Map::new();
    {% for p in op.params if p.location == 'body' %}
    if let Some(v) = args.{{ p.name | rustident }} {
        body_map.insert("{{ p.name }}".to_string(), json!(v));
    }
    {% endfor %}
    let body = if body_map.is_empty() { None } else { Some(serde_json::Value::Object(body_map)) };
    {% else %}
    let body = None;
    {% endif %}
    let result = client.request("{{ op.method }}", &path, &query, body).await?;
    println!("{}", serde_json::to_string_pretty(&result)?);
    Ok(())
}

{% endfor %}
