use clap::Args;
use serde_json::json;

use crate::client::{ApiClient, GlobalOpts};

/// Emit a machine-readable manifest of this CLI for agents.
pub fn agent_context() -> anyhow::Result<()> {
    let ctx = json!({
        "cli": "{{ cli_bin }}",
        "version": "{{ spec.version }}",
        "exit_codes": {
            "3": "not found (404)",
            "4": "auth error (401/403)",
            "5": "API error",
            "7": "rate limited (429)"
        },
        "operations": [
            {% for op in operations %}
            {"command": "{{ op.operation_id | cmd }}", "method": "{{ op.method }}", "path": "{{ op.path }}", "summary": {{ (op.summary or op.description or '') | json }}}{{ "," if not loop.last else "" }}
            {% endfor %}
        ]
    });
    println!("{}", serde_json::to_string_pretty(&ctx)?);
    Ok(())
}

{% for op in operations %}
#[derive(Args)]
pub struct {{ op.operation_id | cmd | rustident }}Args {
    {% for p in dedup(op) if p.location == 'path' %}
    /// {{ p.description }}
    pub {{ p.name | rustident }}: {{ p | rusttype }},
    {% endfor %}
    {% for p in dedup(op) if p.location in ['query', 'body', 'header'] %}
    /// {{ p.description }}
    #[arg(long = "{{ p.name | flag }}")]
    pub {{ p.name | rustident }}: Option<{{ p | rusttype }}>,
    {% endfor %}
}

pub async fn {{ op.operation_id | cmd | rustident }}({% if dedup(op) %}args{% else %}_args{% endif %}: {{ op.operation_id | cmd | rustident }}Args, opts: &GlobalOpts) -> anyhow::Result<()> {
    let client = ApiClient::new(opts.base_url.as_deref());
    let path = "{{ op.path }}"
        {% for p in dedup(op) if p.location == 'path' %}
        .replace("{{ '{' + p.name + '}' }}", &args.{{ p.name | rustident }}.to_string())
        {% endfor %};
    {% if dedup(op) | selectattr('location', 'equalto', 'query') | list %}
    let mut query: Vec<(String, String)> = Vec::new();
    {% for p in dedup(op) if p.location == 'query' %}
    if let Some(v) = &args.{{ p.name | rustident }} {
        {% if p.type == 'array' %}
        for item in v {
            query.push(("{{ p.name }}".to_string(), item.to_string()));
        }
        {% else %}
        query.push(("{{ p.name }}".to_string(), v.to_string()));
        {% endif %}
    }
    {% endfor %}
    {% else %}
    let query: Vec<(String, String)> = Vec::new();
    {% endif %}
    {% if dedup(op) | selectattr('location', 'equalto', 'body') | list %}
    let mut body_map = serde_json::Map::new();
    {% for p in dedup(op) if p.location == 'body' %}
    if let Some(v) = &args.{{ p.name | rustident }} {
        body_map.insert("{{ p.name }}".to_string(), json!(v));
    }
    {% endfor %}
    let body = if body_map.is_empty() { None } else { Some(serde_json::Value::Object(body_map)) };
    {% else %}
    let body: Option<serde_json::Value> = None;
    {% endif %}
    if opts.dry_run {
        let payload = json!({
            "dryRun": true,
            "method": "{{ op.method }}",
            "path": path,
            "url": client.build_url(&path),
            "query": query,
        });
        println!("{}", serde_json::to_string_pretty(&payload)?);
        return Ok(());
    }
    let result = client.request("{{ op.method }}", &path, &query, body).await?;
    println!("{}", serde_json::to_string_pretty(&result)?);
    Ok(())
}

{% endfor %}
