[package]
name = "{{ pkg_name }}"
version = "{{ spec.version }}"
edition = "2021"
description = "Agent-native CLI for {{ spec.display_name or spec.name }} (generated by DuckTap)."

[dependencies]
clap = { version = "4", features = ["derive"] }
reqwest = { version = "0.11", features = ["json"] }
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
anyhow = "1"
colored_json = "4"
