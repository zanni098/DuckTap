{
  "name": "{{ pkg_name }}",
  "version": "{{ spec.version }}",
  "description": "Agent-native CLI for {{ spec.display_name or spec.name }} (generated by DuckTap).",
  "bin": {
    "{{ cli_bin }}": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node ./bin/run.js"
  },
  "dependencies": {
    "@oclif/core": "^3",
    "axios": "^1.6"
  },
  "devDependencies": {
    "typescript": "^5.3"
  },
  "oclif": {
    "bin": "{{ cli_bin }}",
    "dirname": "{{ pkg_name }}",
    "commands": "./dist/commands"
  }
}
