[build-system]
requires = ["hatchling>=1.27"]
build-backend = "hatchling.build"

[project]
name = "{{ bin_name }}"
version = "{{ spec.version }}"
description = "MCP server for {{ spec.display_name or spec.name }} (generated by DuckTap)."
requires-python = ">=3.10"
readme = "README.md"
dependencies = [
    "mcp>=1.0",
    "{{ cli_bin }}",
]

[project.scripts]
{{ bin_name }} = "{{ pkg_name }}.server:main"

[tool.hatch.build.targets.wheel]
packages = ["{{ pkg_name }}"]
