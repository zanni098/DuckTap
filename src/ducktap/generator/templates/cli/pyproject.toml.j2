[build-system]
requires = ["hatchling>=1.27"]
build-backend = "hatchling.build"

[project]
name = "{{ cli_bin }}"
version = "{{ spec.version }}"
description = "Agent-native CLI for {{ spec.display_name or spec.name }} (generated by DuckTap)."
requires-python = ">=3.10"
readme = "README.md"
dependencies = [
    "click>=8.1",
    "httpx>=0.27",
    "rich>=13.7",
]

[project.scripts]
{{ cli_bin }} = "{{ pkg_name }}.main:cli"

[tool.hatch.build.targets.wheel]
packages = ["{{ pkg_name }}"]
