"""Subcommands for {{ spec.display_name or spec.name }}.

Auto-generated by DuckTap. One subcommand per API operation, grouped by the
first tag the operation declares (so `pet add` works like Printing Press).
"""
from __future__ import annotations

import csv
import io
import json
import os
import re
from pathlib import Path
from typing import Any

import click

from .client import Client, APIError

HIGH_GRAVITY_FIELDS = (
    "id", "name", "title", "status", "state", "type", "created_at", "updated_at",
    "createdAt", "updatedAt", "url", "email",
)


def _pick_fields(item: Any, fields: list[str]) -> Any:
    if isinstance(item, dict):
        return {k: item[k] for k in fields if k in item}
    return item


def _compact_item(item: Any) -> Any:
    if isinstance(item, dict):
        kept = {k: item[k] for k in HIGH_GRAVITY_FIELDS if k in item}
        return kept or item
    return item


def _shape(ctx: click.Context, data: Any) -> Any:
    if ctx.obj.get("compact"):
        if isinstance(data, list):
            data = [_compact_item(item) for item in data]
        else:
            data = _compact_item(data)
    fields = ctx.obj.get("select") or []
    if fields:
        if isinstance(data, list):
            data = [_pick_fields(item, fields) for item in data]
        else:
            data = _pick_fields(data, fields)
    return data


def _flatten_keys(items: list[Any]) -> list[str]:
    keys: list[str] = []
    seen: set[str] = set()
    for it in items:
        if isinstance(it, dict):
            for k in it:
                if k not in seen:
                    seen.add(k)
                    keys.append(k)
    return keys


def _format_csv(data: Any) -> str:
    items = data if isinstance(data, list) else [data]
    if not items:
        return ""
    keys = _flatten_keys(items) or ["value"]
    buf = io.StringIO()
    w = csv.DictWriter(buf, fieldnames=keys, extrasaction="ignore")
    w.writeheader()
    for it in items:
        if isinstance(it, dict):
            w.writerow({k: _csv_cell(it.get(k)) for k in keys})
        else:
            w.writerow({keys[0]: _csv_cell(it)})
    return buf.getvalue().rstrip("\n")


def _csv_cell(v: Any) -> str:
    if v is None:
        return ""
    if isinstance(v, (dict, list)):
        return json.dumps(v, separators=(",", ":"), default=str)
    return str(v)


def _format_plain(data: Any) -> str:
    items = data if isinstance(data, list) else [data]
    lines: list[str] = []
    for it in items:
        if isinstance(it, dict):
            ident = it.get("id") or it.get("name") or it.get("title") or ""
            label = it.get("name") or it.get("title") or it.get("status") or ""
            if ident and label and ident != label:
                lines.append(f"{ident}\t{label}")
            else:
                lines.append(str(ident or label or json.dumps(it, default=str)))
        else:
            lines.append(str(it))
    return "\n".join(lines)


def _format_jsonl(data: Any) -> str:
    items = data if isinstance(data, list) else [data]
    return "\n".join(json.dumps(it, default=str) for it in items)


def _emit(ctx: click.Context, data: Any, *, raw: bool = False) -> None:
    """Emit `data` in the active output format.

    `raw=True` skips `_shape()` so --compact/--select do not strip fields off
    metadata payloads (dry-run, agent-context, doctor, profile management).
    Those views are descriptions of the CLI itself, not API response data.
    """
    if ctx.obj.get("quiet"):
        return
    if not raw:
        data = _shape(ctx, data)
    fmt = ctx.obj.get("format", "json")
    if fmt == "json":
        click.echo(json.dumps(data, indent=2, default=str))
    elif fmt == "jsonl":
        click.echo(_format_jsonl(data))
    elif fmt == "csv":
        click.echo(_format_csv(data))
    elif fmt == "plain":
        click.echo(_format_plain(data))
    else:  # pretty
        try:
            from rich.console import Console
            from rich.json import JSON
            Console(no_color=ctx.obj.get("no_color", False)).print(JSON.from_data(data))
        except ImportError:
            click.echo(json.dumps(data, indent=2, default=str))


def _coerce(v: Any) -> Any:
    """If a CLI value looks like a JSON literal (object/array), decode it.
    Lets users pass nested bodies as `--field '{"k":"v"}'` strings.
    """
    if isinstance(v, str) and v and v.strip()[:1] in ("{", "["):
        try:
            return json.loads(v)
        except Exception:
            return v
    return v


def _get_client(ctx: click.Context) -> Client:
    if "client" not in ctx.obj:
        from .mirror import Mirror
        mirror = (
            Mirror(ttl_seconds=ctx.obj.get("cache_ttl", 300))
            if ctx.obj.get("cache") or ctx.obj.get("save") else None
        )
        timeout = ctx.obj.get("timeout") or None
        ctx.obj["client"] = Client(
            mirror=mirror,
            debug=ctx.obj.get("debug", False),
            timeout=timeout,
            rate_limit=ctx.obj.get("rate_limit", 0.0),
        )
    return ctx.obj["client"]


def _exit_code(status: int) -> int:
    if status == 0:
        return 10
    if status == 404:
        return 3
    if status in (401, 403):
        return 4
    if status == 429:
        return 7
    return 5


def _fingerprint(value: str | None) -> str:
    if not value:
        return ""
    return value[:4] + "***" if len(value) > 4 else "***"


def _maybe_save(ctx: click.Context, client: Client, method: str, path: str, data: Any) -> None:
    """Persist response to the local data lake if --save is active."""
    if ctx.obj.get("save") and hasattr(client, "mirror") and client.mirror:
        client.mirror.save_record(
            ctx.obj["save"], method, path,
            client.base_url + path, data,
        )

def _dry_run_payload(client: Client, method: str, path: str,
                     query: dict[str, Any], headers: dict[str, str],
                     body: Any) -> dict[str, Any]:
    return {
        "method": method,
        "path": path,
        "url": client.base_url + path,
        "query": query,
        "headers": {k: ("***" if k.lower() in ("authorization", "api_key", "x-api-key") else v)
                    for k, v in headers.items()},
        "body": body,
    }


# Pre-baked, sorted list of (tag-group, operation-id, method, path, summary).
# Used by `agent-context` and `which`.
_OPERATIONS: list[dict[str, Any]] = [
    {% for op in operations %}{
        "group": {{ ((op.tags[0] if op.tags else "general") | cmd) | tojson }},
        "id": {{ (op.operation_id | cmd) | tojson }},
        "raw_id": {{ op.operation_id | tojson }},
        "method": {{ op.method | tojson }},
        "path": {{ op.path | tojson }},
        "summary": {{ (op.summary or op.description or "") | tojson }},
        "deprecated": {{ "True" if op.deprecated else "False" }},
    },
    {% endfor %}
]


def _profiles_dir() -> Path:
    return Path.home() / ".ducktap" / "{{ spec.name }}" / "profiles"


def register(cli: click.Group) -> None:
    @cli.command("doctor", help="Inspect local configuration without calling write endpoints.")
    @click.pass_context
    def doctor(ctx: click.Context) -> None:
        client = _get_client(ctx)
        auth = []
        {% for s in spec.auth_schemes %}
        v = os.environ.get("{{ s.env_var }}")
        auth.append({
            "name": "{{ s.name }}",
            "env_var": "{{ s.env_var }}",
            "type": "{{ s.type }}",
            "set": bool(v),
            "fingerprint": _fingerprint(v),
        })
        {% endfor %}
        mirror_path = Path.home() / ".ducktap" / "{{ spec.name }}" / "mirror.sqlite"
        cache_state = {
            "enabled": bool(ctx.obj.get("cache")),
            "ttl_seconds": ctx.obj.get("cache_ttl", 300),
            "path": str(mirror_path),
            "exists": mirror_path.exists(),
            "size_bytes": mirror_path.stat().st_size if mirror_path.exists() else 0,
        }
        prof_dir = _profiles_dir()
        profiles = sorted([p.stem for p in prof_dir.glob("*.json")]) if prof_dir.exists() else []
        _emit(ctx, {
            "cli": "{{ cli_bin }}",
            "base_url": {
                "value": client.base_url,
                "configured": bool(client.base_url),
                "valid_url": client.base_url.startswith(("http://", "https://")),
            },
            "auth": auth,
            "cache": cache_state,
            "profiles": {
                "active": ctx.obj.get("profile"),
                "available": profiles,
                "dir": str(prof_dir),
            },
            "operations": len(_OPERATIONS),
            "groups": sorted({op["group"] for op in _OPERATIONS}),
        }, raw=True)

    @cli.command("auth-doctor",
                 help="Validate auth env vars and optionally probe the API to "
                      "confirm credentials are accepted.")
    @click.option("--probe/--no-probe", default=False,
                  help="Make a real GET request to confirm credentials work.")
    @click.pass_context
    def auth_doctor(ctx: click.Context, probe: bool) -> None:
        schemes: list[dict[str, Any]] = []
        {% for s in spec.auth_schemes %}
        v = os.environ.get("{{ s.env_var }}")
        desc = {{ (s.description or "") | tojson }}
        if v:
            hint = "Credential set."
        else:
            hint = "Set {{ s.env_var }} before running."
            if desc:
                hint += " " + desc
        schemes.append({
            "name": "{{ s.name }}",
            "type": "{{ s.type }}",
            "location": "{{ s.location }}",
            "parameter_name": "{{ s.parameter_name }}",
            "env_var": "{{ s.env_var }}",
            "set": bool(v),
            "fingerprint": _fingerprint(v),
            "hint": hint,
        })
        {% endfor %}

        set_count = sum(1 for s in schemes if s["set"])
        summary = {
            "set": set_count,
            "unset": len(schemes) - set_count,
            "total": len(schemes),
            "all_set": set_count == len(schemes) and len(schemes) > 0,
        }

        probe_result: dict[str, Any] | None = None
        if probe:
            probe_op = next(
                (op for op in _OPERATIONS
                 if op["method"] == "GET" and "{" not in op["path"]),
                None,
            )
            if probe_op is None:
                probe_result = {
                    "status": "skipped",
                    "reason": "no GET operation without path params to probe",
                }
            else:
                client = _get_client(ctx)
                probe_url = client.base_url + probe_op["path"]
                try:
                    client.request("GET", probe_op["path"], use_cache=False)
                    probe_result = {
                        "status": "ok",
                        "classification": "auth_works",
                        "http_status": 200,
                        "probed_op": probe_op["raw_id"],
                        "url": probe_url,
                    }
                except APIError as exc:
                    if exc.status in (401, 403):
                        classification = (
                            "auth_failed" if summary["all_set"] else "auth_missing"
                        )
                    elif exc.status == 429:
                        classification = "rate_limited"
                    elif exc.status == 0:
                        classification = "no_base_url"
                    else:
                        classification = "inconclusive"
                    probe_result = {
                        "status": "ok",
                        "classification": classification,
                        "http_status": exc.status,
                        "probed_op": probe_op["raw_id"],
                        "url": probe_url,
                    }
                except Exception as exc:
                    probe_result = {
                        "status": "network_error",
                        "classification": "network_error",
                        "error": str(exc),
                        "probed_op": probe_op["raw_id"],
                        "url": probe_url,
                    }

        _emit(ctx, {
            "cli": "{{ cli_bin }}",
            "summary": summary,
            "schemes": schemes,
            "probe": probe_result,
        }, raw=True)
        # Exit code is the strongest signal an agent can act on without
        # parsing JSON; map to the same palette `doctor`/operations use.
        cls = (probe_result or {}).get("classification")
        if cls in ("auth_failed", "auth_missing"):
            ctx.exit(4)
        if cls == "rate_limited":
            ctx.exit(7)
        if cls == "no_base_url":
            ctx.exit(10)
        if cls == "network_error":
            ctx.exit(5)
        if not summary["all_set"]:
            ctx.exit(10)

    @cli.command("agent-context",
                 help="Emit structured JSON describing this CLI for agents.")
    @click.pass_context
    def agent_context(ctx: click.Context) -> None:
        groups: dict[str, list[dict[str, Any]]] = {}
        for op in _OPERATIONS:
            groups.setdefault(op["group"], []).append({
                "id": op["id"],
                "raw_id": op["raw_id"],
                "method": op["method"],
                "path": op["path"],
                "summary": op["summary"],
                "deprecated": op["deprecated"],
            })
        client = _get_client(ctx)
        _emit(ctx, {
            "cli": "{{ cli_bin }}",
            "name": "{{ spec.name }}",
            "display_name": "{{ spec.display_name or spec.name }}",
            "version": "{{ spec.version }}",
            "ducktap_version": "{{ ducktap_version }}",
            "base_url": client.base_url,
            "auth_env_vars": [{% for s in spec.auth_schemes %}"{{ s.env_var }}",{% endfor %}],
            "global_flags": [
                "--agent", "--json", "--pretty", "--no-color",
                "--format=json|jsonl|csv|plain|pretty",
                "--select id,name", "--compact", "--quiet", "--dry-run",
                "--rate-limit N", "--timeout SECONDS",
                "--profile NAME", "--cache/--no-cache", "--cache-ttl",
                "--debug",
            ],
            "exit_codes": {
                "0": "success",
                "3": "404 not found",
                "4": "401/403 auth",
                "5": "other API error",
                "7": "429 rate limited",
                "10": "local configuration error",
            },
            "groups": groups,
            "operations": _OPERATIONS,
        }, raw=True)

    @cli.command("which",
                 help="Search commands by keyword (matches id, path, and summary).")
    @click.argument("keyword", required=False, default="")
    @click.pass_context
    def which_cmd(ctx: click.Context, keyword: str) -> None:
        pat = re.compile(re.escape(keyword), re.IGNORECASE) if keyword else None
        matches = []
        for op in _OPERATIONS:
            blob = " ".join((op["id"], op["raw_id"], op["path"], op["summary"]))
            if pat is None or pat.search(blob):
                matches.append({
                    "command": f"{{ cli_bin }} {op['group']} {op['id']}"
                               if op["group"] != "general" else f"{{ cli_bin }} {op['id']}",
                    "method": op["method"],
                    "path": op["path"],
                    "summary": op["summary"],
                })
        _emit(ctx, matches, raw=True)
        if not matches:
            ctx.exit(3)

    profile_group = click.Group(name="profile",
                                help="Manage saved flag presets in "
                                     "~/.ducktap/{{ spec.name }}/profiles/.")
    cli.add_command(profile_group)

    @profile_group.command("list")
    @click.pass_context
    def profile_list(ctx: click.Context) -> None:
        d = _profiles_dir()
        items = []
        if d.exists():
            for p in sorted(d.glob("*.json")):
                try:
                    items.append({"name": p.stem,
                                  "values": json.loads(p.read_text(encoding="utf-8"))})
                except Exception:
                    items.append({"name": p.stem, "values": None})
        _emit(ctx, {"dir": str(d), "profiles": items}, raw=True)

    @profile_group.command("save")
    @click.argument("name")
    @click.option("--format", "save_format",
                  type=click.Choice(["json", "jsonl", "csv", "plain", "pretty"]),
                  default=None)
    @click.option("--select", "save_select", default=None)
    @click.option("--compact/--no-compact", default=None)
    @click.option("--quiet/--no-quiet", default=None)
    @click.option("--debug/--no-debug", default=None)
    @click.option("--no-color/--color", default=None)
    @click.option("--rate-limit", type=float, default=None)
    @click.option("--timeout", type=float, default=None)
    @click.option("--cache-ttl", type=int, default=None)
    @click.pass_context
    def profile_save(ctx: click.Context, name: str, save_format: str | None,
                     save_select: str | None, compact: bool | None,
                     quiet: bool | None, debug: bool | None,
                     no_color: bool | None, rate_limit: float | None,
                     timeout: float | None, cache_ttl: int | None) -> None:
        d = _profiles_dir()
        d.mkdir(parents=True, exist_ok=True)
        body: dict[str, Any] = {}
        if save_format is not None:
            body["format"] = save_format
        if save_select is not None:
            body["select"] = save_select
        if compact is not None:
            body["compact"] = compact
        if quiet is not None:
            body["quiet"] = quiet
        if debug is not None:
            body["debug"] = debug
        if no_color is not None:
            body["no_color"] = no_color
        if rate_limit is not None:
            body["rate_limit"] = rate_limit
        if timeout is not None:
            body["timeout"] = timeout
        if cache_ttl is not None:
            body["cache_ttl"] = cache_ttl
        path = d / f"{name}.json"
        path.write_text(json.dumps(body, indent=2), encoding="utf-8")
        _emit(ctx, {"saved": str(path), "values": body}, raw=True)

    @profile_group.command("show")
    @click.argument("name")
    @click.pass_context
    def profile_show(ctx: click.Context, name: str) -> None:
        path = _profiles_dir() / f"{name}.json"
        if not path.exists():
            click.echo(json.dumps({"error": f"no such profile: {name}"}), err=True)
            ctx.exit(3)
        _emit(ctx, json.loads(path.read_text(encoding="utf-8")), raw=True)

    data_group = click.Group(name="data",
                             help="Query and search the local response lake.")
    cli.add_command(data_group)

    @data_group.command("query")
    @click.argument("sql")
    @click.pass_context
    def data_query(ctx: click.Context, sql: str) -> None:
        """Run read-only SQL over saved / cached responses."""
        client = _get_client(ctx)
        mirror = getattr(client, "mirror", None)
        if not mirror:
            click.echo(json.dumps({"error": "no mirror available -- use --save or --cache"}), err=True)
            ctx.exit(10)
        try:
            rows = mirror.query(sql)
        except ValueError as e:
            click.echo(json.dumps({"error": str(e)}), err=True)
            ctx.exit(10)
        _emit(ctx, rows, raw=True)

    @data_group.command("search")
    @click.argument("text")
    @click.option("--limit", type=int, default=20, show_default=True)
    @click.pass_context
    def data_search(ctx: click.Context, text: str, limit: int) -> None:
        """Full-text search over saved JSON bodies."""
        client = _get_client(ctx)
        mirror = getattr(client, "mirror", None)
        if not mirror:
            click.echo(json.dumps({"error": "no mirror available -- use --save or --cache"}), err=True)
            ctx.exit(10)
        rows = mirror.search(text, limit=limit)
        _emit(ctx, rows, raw=True)

    # ------------------------------------------------------------------
    # Tag-grouped operation tree. Operations are registered under their
    # first tag (kebab-cased). Operations without a usable tag remain at
    # the top level under the "general" pseudo-group.
    # ------------------------------------------------------------------
    _groups: dict[str, click.Group] = {}

    def _get_group(name: str) -> click.Group | None:
        if name == "general":
            return None
        if name not in _groups:
            grp = click.Group(name=name,
                              help=f"{name} operations.")
            cli.add_command(grp)
            _groups[name] = grp
        return _groups[name]

    {% for op in operations %}
    {% set group_name = (op.tags[0] if op.tags else "general") | cmd %}
    {% set _ns = namespace(seen=[]) %}
    {% set _ = _ns.seen.append("__placeholder__") %}
    _target = _get_group({{ group_name | tojson }}) or cli

    @_target.command(
        "{{ op.operation_id | cmd }}",
        help={{ (op.summary or op.description or op.operation_id) | tojson }},
    )
    {% for p in op.params %}
    {% set _flag = p.name | flag %}
    {% if _flag in _ns.seen %}
    {% set _flag = "--body-" + (p.name | flag | replace("--", "")) %}
    {% endif %}
    {% set _ = _ns.seen.append(_flag) %}
    {% if p.location == "path" %}
    @click.option(
        "{{ _flag }}",
        "{{ p.name | pyident }}",
        type={{ p | clicktype }},
        required=True,
        help={{ ("Path parameter: " + (p.description or p.name)) | tojson }},
    )
    {% elif p.location == "query" %}
    @click.option(
        "{{ _flag }}",
        "{{ p.name | pyident }}",
        type={{ p | clicktype }},
{% if p.default is not none %}
        default={{ p.default | pyrepr }},
        show_default=True,
{% else %}
        required={{ "True" if p.required else "False" }},
{% endif %}
        help={{ (p.description or "Query parameter: " + p.name) | tojson }},
    )
    {% elif p.location == "header" %}
    @click.option(
        "{{ _flag }}",
        "{{ p.name | pyident }}",
        type={{ p | clicktype }},
        required={{ "True" if p.required else "False" }},
        help={{ ("Header: " + (p.description or p.name)) | tojson }},
    )
    {% elif p.location == "body" %}
    @click.option(
        "{{ _flag }}",
        "{{ p.name | pyident }}",
        type=str,
        required={{ "True" if p.required else "False" }},
        help={{ ("Body field: " + (p.description or p.name)) | tojson }},
    )
    {% endif %}
    {% endfor %}
    @click.pass_context
    def {{ op.operation_id | pyident }}(ctx: click.Context, **kwargs: Any) -> None:
        path = "{{ op.path }}"
        {% for p in op.params if p.location == "path" %}
        path = path.replace("{{ '{' + p.name + '}' }}", str(kwargs.pop("{{ p.name | pyident }}")))
        {% endfor %}
        query: dict[str, Any] = {}
        {% for p in op.params if p.location == "query" %}
        if kwargs.get("{{ p.name | pyident }}") is not None:
            query["{{ p.name }}"] = kwargs.pop("{{ p.name | pyident }}")
        {% endfor %}
        headers: dict[str, str] = {}
        {% for p in op.params if p.location == "header" %}
        if kwargs.get("{{ p.name | pyident }}") is not None:
            headers["{{ p.name }}"] = kwargs.pop("{{ p.name | pyident }}")
        {% endfor %}
        body: Any = None
        {% set bps = op.params | selectattr("location", "equalto", "body") | list %}
        {% if bps %}
        body = {}
        {% for p in bps %}
        if kwargs.get("{{ p.name | pyident }}") is not None:
            body["{{ p.name }}"] = _coerce(kwargs.pop("{{ p.name | pyident }}"))
        {% endfor %}
        if not body:
            body = None
        {% endif %}
        client = _get_client(ctx)
        if ctx.obj.get("dry_run"):
            # Dry-run payload describes the request, not response data, so
            # skip --compact/--select. Otherwise --agent (which implies
            # --compact) collapses the payload to a single high-gravity key.
            _emit(ctx, _dry_run_payload(client, "{{ op.method }}", path, query, headers, body),
                  raw=True)
            return
        try:
            data = client.request(
                "{{ op.method }}", path,
                query=query, headers=headers, json_body=body,
                use_cache=("{{ op.method }}" == "GET"),
            )
        except APIError as e:
            click.echo(json.dumps({"error": str(e), "status": e.status, "body": e.body},
                                  indent=2, default=str), err=True)
            ctx.exit(_exit_code(e.status))
        _maybe_save(ctx, client, "{{ op.method }}", path, data)
        _emit(ctx, data)

    {% endfor %}
