HIGH_GRAVITY_FIELDS = (
    "id", "name", "title", "status", "state", "type", "created_at", "updated_at",
    "createdAt", "updatedAt", "url", "email",
)


def _pick_fields(item: Any, fields: list[str]) -> Any:
    if isinstance(item, dict):
        return {k: item[k] for k in fields if k in item}
    return item


def _compact_item(item: Any) -> Any:
    if isinstance(item, dict):
        kept = {k: item[k] for k in HIGH_GRAVITY_FIELDS if k in item}
        return kept or item
    return item


def _shape(ctx: click.Context, data: Any) -> Any:
    if ctx.obj.get("compact"):
        if isinstance(data, list):
            data = [_compact_item(item) for item in data]
        else:
            data = _compact_item(data)
    fields = ctx.obj.get("select") or []
    if fields:
        if isinstance(data, list):
            data = [_pick_fields(item, fields) for item in data]
        else:
            data = _pick_fields(data, fields)
    return data


def _emit(ctx: click.Context, data: Any) -> None:
    if ctx.obj.get("quiet"):
        return
    data = _shape(ctx, data)
    fmt = ctx.obj.get("format", "json")
    if fmt == "json":
        click.echo(json.dumps(data, indent=2, default=str))
    else:
        try:
            from rich.console import Console
            from rich.json import JSON
            Console().print(JSON.from_data(data))
        except ImportError:
            click.echo(json.dumps(data, indent=2, default=str))


def _coerce(v: Any) -> Any:
    """If a CLI value looks like a JSON literal (object/array), decode it.
    Lets users pass nested bodies as `--field '{"k":"v"}'` strings.
    """
    if isinstance(v, str) and v and v.strip()[:1] in ("{", "["):
        try:
            return json.loads(v)
        except Exception:
            return v
    return v


def _get_client(ctx: click.Context) -> Client:
    if "client" not in ctx.obj:
        from .mirror import Mirror
        mirror = Mirror(ttl_seconds=ctx.obj.get("cache_ttl", 300)) if ctx.obj.get("cache") else None
        ctx.obj["client"] = Client(mirror=mirror, debug=ctx.obj.get("debug", False))
    return ctx.obj["client"]


def _exit_code(status: int) -> int:
    if status == 0:
        return 10
    if status == 404:
        return 3
    if status in (401, 403):
        return 4
    if status == 429:
        return 7
    return 5


def _fingerprint(value: str | None) -> str:
    if not value:
        return ""
    return value[:4] + "***" if len(value) > 4 else "***"


def _dry_run_payload(client: Client, method: str, path: str,
                     query: dict[str, Any], headers: dict[str, str],
