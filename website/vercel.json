{
  "version": 2,
  "routes": [
    {
      "src": "/style\\.css",
      "dest": "/style.css"
    },
    {
      "src": "/script\\.js",
      "dest": "/script.js"
    },
    {
      "src": "/duck-logo\\.svg",
      "dest": "/duck-logo.svg"
    },
    {
      "src": "/favicon-.*\\.png",
      "dest": "/favicon-:match.png"
    },
    {
      "src": "/apple-touch-icon\\.png",
      "dest": "/apple-touch-icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
